<Activity x:Class="Main" 
    xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" 
    xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:core="http://schemas.microsoft.com/netfx/2009/xaml/activities" 
    xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib" 
    xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib" 
    xmlns:ui="http://schemas.uipath.com/workflow/activities" 
    xmlns:uix="http://schemas.uipath.com/workflow/activities/uix" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Sequence DisplayName="DHL Knowledge Base Automation - Main Orchestrator">
        
        <!-- ============================================ -->
        <!-- VARIABLE DECLARATIONS                        -->
        <!-- ============================================ -->
        
        <!-- Statistics Counters -->
        <ui:Assign x:TypeArguments="x:Int32" DisplayName="Initialize Created Counter">
            <ui:To>
                <OutArgument x:TypeArguments="x:Int32">[intCreatedCount]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="x:Int32">0</InArgument>
            </ui:From>
        </ui:Assign>
        
        <ui:Assign x:TypeArguments="x:Int32" DisplayName="Initialize Updated Counter">
            <ui:To>
                <OutArgument x:TypeArguments="x:Int32">[intUpdatedCount]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="x:Int32">0</InArgument>
            </ui:From>
        </ui:Assign>
        
        <ui:Assign x:TypeArguments="x:Int32" DisplayName="Initialize Duplicate Counter">
            <ui:To>
                <OutArgument x:TypeArguments="x:Int32">[intDuplicateCount]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="x:Int32">0</InArgument>
            </ui:From>
        </ui:Assign>
        
        <ui:Assign x:TypeArguments="x:Int32" DisplayName="Initialize Failed Counter">
            <ui:To>
                <OutArgument x:TypeArguments="x:Int32">[intFailedCount]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="x:Int32">0</InArgument>
            </ui:From>
        </ui:Assign>
        
        <!-- Log Collection -->
        <ui:Assign x:TypeArguments="scg:List(x:String)" DisplayName="Initialize Log List">
            <ui:To>
                <OutArgument x:TypeArguments="scg:List(x:String)">[lstExecutionLogs]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="scg:List(x:String)">New List(Of String)</InArgument>
            </ui:From>
        </ui:Assign>
        
        <!-- File List -->
        <ui:Assign x:TypeArguments="scg:List(x:String)" DisplayName="Initialize File List">
            <ui:To>
                <OutArgument x:TypeArguments="scg:List(x:String)">[lstFiles]</OutArgument>
            </ui:To>
            <ui:From>
                <InArgument x:TypeArguments="scg:List(x:String)">New List(Of String)</InArgument>
            </ui:From>
        </ui:Assign>
        
        <!-- ============================================ -->
        <!-- 1. LOG EXECUTION START                       -->
        <!-- ============================================ -->
        
        <ui:WriteLine DisplayName="Log Start Time" 
                      Text="[&quot;=== DHL RPA Bot Started: &quot; + DateTime.Now.ToString(&quot;yyyy-MM-dd HH:mm:ss&quot;) + &quot; ===&quot;]" />
        
        <ui:AddToCollection x:TypeArguments="x:String" 
                            DisplayName="Add Start Log" 
                            Collection="[lstExecutionLogs]" 
                            Value="[&quot;=== DHL RPA Execution Started: &quot; + DateTime.Now.ToString() + &quot; ===&quot;]" />
        
        <!-- ============================================ -->
        <!-- 2. READ CONFIGURATION FILE                   -->
        <!-- ============================================ -->
        
        <ui:ReadRange AddHeaders="True" 
                      DisplayName="Read Configuration" 
                      Range="A1:G10" 
                      SheetName="Config" 
                      WorkbookPath="Config.xlsx" 
                      Result="[dtConfig]" />
        
        <ui:AddToCollection x:TypeArguments="x:String" 
                            DisplayName="Log Config Loaded" 
                            Collection="[lstExecutionLogs]" 
                            Value="[&quot;[INFO] Configuration loaded successfully&quot;]" />
        
        <!-- ============================================ -->
        <!-- 3. SCAN GOOGLE DRIVE / INPUT FOLDER          -->
        <!-- ============================================ -->
        
        <ui:InvokeWorkflowFile DisplayName="Read Files from Input Source" 
                               FileName="Read_Inputs.xaml">
            <ui:InArgument x:TypeArguments="x:String" x:Name="inFolderPath">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("DriveFolderPath").ToString()]</InArgument>
            </ui:InArgument>
            <ui:OutArgument x:TypeArguments="scg:List(x:String)" x:Name="outFileList">
                <OutArgument x:TypeArguments="scg:List(x:String)">[lstFiles]</OutArgument>
            </ui:OutArgument>
        </ui:InvokeWorkflowFile>
        
        <ui:AddToCollection x:TypeArguments="x:String" 
                            DisplayName="Log Files Found" 
                            Collection="[lstExecutionLogs]" 
                            Value="[&quot;[INFO] Found &quot; + lstFiles.Count.ToString() + &quot; files to process&quot;]" />
        
        <!-- ============================================ -->
        <!-- 4. PROCESS EACH FILE                         -->
        <!-- ============================================ -->
        
        <ui:ForEach x:TypeArguments="x:String" 
                    DisplayName="For Each File" 
                    Values="[lstFiles]">
            <ActivityAction x:TypeArguments="x:String">
                <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="x:String" Name="currentFilePath" />
                </ActivityAction.Argument>
                <Sequence DisplayName="Process Single File">
                    
                    <!-- 4a. Calculate File Hash -->
                    <ui:GetFileHash Algorithm="SHA256" 
                                     DisplayName="Calculate File Hash" 
                                     FileName="[currentFilePath]">
                        <ui:Result>
                            <OutArgument x:TypeArguments="x:String">[strFileHash]</OutArgument>
                        </ui:Result>
                    </ui:GetFileHash>
                    
                    <!-- 4b. Check for Duplicate -->
                    <ui:InvokeWorkflowFile DisplayName="Check Duplicate in Database" 
                                           FileName="Check_Duplicate.xaml">
                        <ui:InArgument x:TypeArguments="x:String" x:Name="inFileHash">
                            <InArgument x:TypeArguments="x:String">[strFileHash]</InArgument>
                        </ui:InArgument>
                        <ui:OutArgument x:TypeArguments="x:Boolean" x:Name="outIsDuplicate">
                            <OutArgument x:TypeArguments="x:Boolean">[isDuplicate]</OutArgument>
                        </ui:OutArgument>
                        <ui:OutArgument x:TypeArguments="x:Int32" x:Name="outExistingId">
                            <OutArgument x:TypeArguments="x:Int32">[existingArticleId]</OutArgument>
                        </ui:OutArgument>
                    </ui:InvokeWorkflowFile>
                    
                    <!-- 4c. Handle Duplicate or Process -->
                    <ui:If Condition="[isDuplicate]" DisplayName="Check if Duplicate">
                        <ui:If.Then>
                            <Sequence DisplayName="Handle Duplicate File">
                                <ui:Assign x:TypeArguments="x:Int32" DisplayName="Increment Duplicate Counter">
                                    <ui:To>[intDuplicateCount]</ui:To>
                                    <ui:From>[intDuplicateCount + 1]</ui:From>
                                </ui:Assign>
                                
                                <ui:AddToCollection x:TypeArguments="x:String" 
                                                    DisplayName="Log Duplicate" 
                                                    Collection="[lstExecutionLogs]" 
                                                    Value="[&quot;[DUPLICATE] &quot; + Path.GetFileName(currentFilePath) + &quot; - Already processed within 14 days (ID: &quot; + existingArticleId.ToString() + &quot;)&quot;]" />
                                
                                <ui:WriteLine DisplayName="Write Duplicate Log" 
                                              Text="[&quot;[DUPLICATE] Skipped: &quot; + Path.GetFileName(currentFilePath)]" />
                            </Sequence>
                        </ui:If.Then>
                        
                        <ui:If.Else>
                            <Sequence DisplayName="Process New File">
                                
                                <!-- Error Handling Wrapper -->
                                <ui:TryCatch DisplayName="Try-Catch for File Processing">
                                    <ui:TryCatch.Try>
                                        <Sequence DisplayName="Process File Success Path">
                                            
                                            <!-- 4d. Read File Content -->
                                            <ui:InvokeWorkflowFile DisplayName="Read File Content" 
                                                                   FileName="Read_File_Content.xaml">
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inFilePath">
                                                    <InArgument x:TypeArguments="x:String">[currentFilePath]</InArgument>
                                                </ui:InArgument>
                                                <ui:OutArgument x:TypeArguments="x:String" x:Name="outFileContent">
                                                    <OutArgument x:TypeArguments="x:String">[strFileContent]</OutArgument>
                                                </ui:OutArgument>
                                                <ui:OutArgument x:TypeArguments="x:String" x:Name="outFileName">
                                                    <OutArgument x:TypeArguments="x:String">[strFileName]</OutArgument>
                                                </ui:OutArgument>
                                                <ui:OutArgument x:TypeArguments="x:String" x:Name="outFileType">
                                                    <OutArgument x:TypeArguments="x:String">[strFileType]</OutArgument>
                                                </ui:OutArgument>
                                            </ui:InvokeWorkflowFile>
                                            
                                            <!-- 4e. Process with AI and Create Article -->
                                            <ui:InvokeWorkflowFile DisplayName="Process Article with AI" 
                                                                   FileName="Process_Article.xaml">
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inContent">
                                                    <InArgument x:TypeArguments="x:String">[strFileContent]</InArgument>
                                                </ui:InArgument>
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inFileName">
                                                    <InArgument x:TypeArguments="x:String">[strFileName]</InArgument>
                                                </ui:InArgument>
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inFileType">
                                                    <InArgument x:TypeArguments="x:String">[strFileType]</InArgument>
                                                </ui:InArgument>
                                                <ui:OutArgument x:TypeArguments="x:Int32" x:Name="outArticleId">
                                                    <OutArgument x:TypeArguments="x:Int32">[newArticleId]</OutArgument>
                                                </ui:OutArgument>
                                            </ui:InvokeWorkflowFile>
                                            
                                            <!-- 4f. Update Web Application -->
                                            <ui:InvokeWorkflowFile DisplayName="Update Web Application Status" 
                                                                   FileName="Update_WebApp.xaml">
                                                <ui:InArgument x:TypeArguments="x:Int32" x:Name="inArticleId">
                                                    <InArgument x:TypeArguments="x:Int32">[newArticleId]</InArgument>
                                                </ui:InArgument>
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inContent">
                                                    <InArgument x:TypeArguments="x:String">[strFileContent]</InArgument>
                                                </ui:InArgument>
                                                <ui:InArgument x:TypeArguments="x:String" x:Name="inTitle">
                                                    <InArgument x:TypeArguments="x:String">[strFileName]</InArgument>
                                                </ui:InArgument>
                                            </ui:InvokeWorkflowFile>
                                            
                                            <!-- 4g. Increment Success Counter -->
                                            <ui:Assign x:TypeArguments="x:Int32" DisplayName="Increment Created Counter">
                                                <ui:To>[intCreatedCount]</ui:To>
                                                <ui:From>[intCreatedCount + 1]</ui:From>
                                            </ui:Assign>
                                            
                                            <ui:AddToCollection x:TypeArguments="x:String" 
                                                                DisplayName="Log Success" 
                                                                Collection="[lstExecutionLogs]" 
                                                                Value="[&quot;[SUCCESS] &quot; + strFileName + &quot; - Created article ID: &quot; + newArticleId.ToString() + &quot; (Type: &quot; + strFileType + &quot;)&quot;]" />
                                            
                                            <ui:WriteLine DisplayName="Write Success Log" 
                                                          Text="[&quot;[SUCCESS] Processed: &quot; + strFileName + &quot; → Article ID: &quot; + newArticleId.ToString()]" />
                                            
                                            <!-- 4h. Move Processed File to Archive -->
                                            <ui:MoveFile DisplayName="Archive Processed File" 
                                                         Path="[currentFilePath]" 
                                                         Destination="[dtConfig.Rows(0).Item(&quot;ArchiveFolderPath&quot;).ToString() + &quot;\&quot; + DateTime.Now.ToString(&quot;yyyyMMdd&quot;) + &quot;_&quot; + Path.GetFileName(currentFilePath)]" 
                                                         Overwrite="True" />
                                            
                                        </Sequence>
                                    </ui:TryCatch.Try>
                                    
                                    <ui:TryCatch.Catches>
                                        <ui:Catch x:TypeArguments="s:Exception" DisplayName="Catch Processing Error">
                                            <ActivityAction x:TypeArguments="s:Exception">
                                                <ActivityAction.Argument>
                                                    <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
                                                </ActivityAction.Argument>
                                                <Sequence DisplayName="Handle Processing Error">
                                                    
                                                    <!-- Take Screenshot on Error -->
                                                    <ui:TakeScreenshot DisplayName="Capture Error Screenshot" 
                                                                       SavePath="[dtConfig.Rows(0).Item(&quot;LogFolderPath&quot;).ToString() + &quot;\error_&quot; + DateTime.Now.ToString(&quot;yyyyMMdd_HHmmss&quot;) + &quot;.png&quot;]" />
                                                    
                                                    <!-- Write Error to Log -->
                                                    <ui:AddToCollection x:TypeArguments="x:String" 
                                                                        DisplayName="Log Error" 
                                                                        Collection="[lstExecutionLogs]" 
                                                                        Value="[&quot;[ERROR] &quot; + Path.GetFileName(currentFilePath) + &quot;: &quot; + exception.Message&quot;]" />
                                                    
                                                    <!-- Increment Failed Counter -->
                                                    <ui:Assign x:TypeArguments="x:Int32" DisplayName="Increment Failed Counter">
                                                        <ui:To>[intFailedCount]</ui:To>
                                                        <ui:From>[intFailedCount + 1]</ui:From>
                                                    </ui:Assign>
                                                    
                                                    <!-- Move Failed File to Error Folder -->
                                                    <ui:MoveFile DisplayName="Move Failed File to Error Folder" 
                                                                 Path="[currentFilePath]" 
                                                                 Destination="[dtConfig.Rows(0).Item(&quot;ErrorFolderPath&quot;).ToString() + &quot;\&quot; + DateTime.Now.ToString(&quot;yyyyMMdd&quot;) + &quot;_&quot; + Path.GetFileName(currentFilePath)]" 
                                                                 Overwrite="True" />
                                                    
                                                    <ui:WriteLine DisplayName="Write Error Log" 
                                                                  Text="[&quot;[ERROR] Failed: &quot; + Path.GetFileName(currentFilePath) + &quot; - &quot; + exception.Message&quot;]" />
                                                </Sequence>
                                            </ActivityAction>
                                        </ui:Catch>
                                    </ui:TryCatch.Catches>
                                </ui:TryCatch>
                                
                            </Sequence>
                        </ui:If.Else>
                    </ui:If>
                    
                </Sequence>
            </ActivityAction>
        </ui:ForEach>
        
        <!-- ============================================ -->
        <!-- 5. SEND SUMMARY EMAIL                        -->
        <!-- ============================================ -->
        
        <ui:AddToCollection x:TypeArguments="x:String" 
                            DisplayName="Add Summary to Log" 
                            Collection="[lstExecutionLogs]" 
                            Value="[&quot;[SUMMARY] Created: &quot; + intCreatedCount.ToString() + &quot; | Updated: &quot; + intUpdatedCount.ToString() + &quot; | Duplicates: &quot; + intDuplicateCount.ToString() + &quot; | Failed: &quot; + intFailedCount.ToString()]" />
        
        <ui:InvokeWorkflowFile DisplayName="Send Summary Email Report" 
                               FileName="Send_Email.xaml">
            <ui:InArgument x:TypeArguments="x:Int32" x:Name="inCreatedCount">
                <InArgument x:TypeArguments="x:Int32">[intCreatedCount]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:Int32" x:Name="inUpdatedCount">
                <InArgument x:TypeArguments="x:Int32">[intUpdatedCount]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:Int32" x:Name="inDuplicateCount">
                <InArgument x:TypeArguments="x:Int32">[intDuplicateCount]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:Int32" x:Name="inFailedCount">
                <InArgument x:TypeArguments="x:Int32">[intFailedCount]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="scg:List(x:String)" x:Name="inLogs">
                <InArgument x:TypeArguments="scg:List(x:String)">[lstExecutionLogs]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:String" x:Name="inSenderEmail">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("SenderEmail").ToString()]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:String" x:Name="inRecipientEmail">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("RecipientEmail").ToString()]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:String" x:Name="inSmtpServer">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("SmtpServer").ToString()]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:Int32" x:Name="inSmtpPort">
                <InArgument x:TypeArguments="x:Int32">[CInt(dtConfig.Rows(0).Item("SmtpPort"))]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:String" x:Name="inSmtpUsername">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("SmtpUsername").ToString()]</InArgument>
            </ui:InArgument>
            <ui:InArgument x:TypeArguments="x:String" x:Name="inSmtpPassword">
                <InArgument x:TypeArguments="x:String">[dtConfig.Rows(0).Item("SmtpPassword").ToString()]</InArgument>
            </ui:InArgument>
        </ui:InvokeWorkflowFile>
        
        <!-- ============================================ -->
        <!-- 6. LOG EXECUTION COMPLETION                  -->
        <!-- ============================================ -->
        
        <ui:WriteLine DisplayName="Log Completion Time" 
                      Text="[&quot;=== DHL RPA Bot Completed at: &quot; + DateTime.Now.ToString(&quot;yyyy-MM-dd HH:mm:ss&quot;) + &quot; ===&quot;]" />
        
        <ui:WriteLine DisplayName="Log Final Statistics" 
                      Text="[&quot;[FINAL] Created: &quot; + intCreatedCount.ToString() + &quot;, Updated: &quot; + intUpdatedCount.ToString() + &quot;, Duplicates: &quot; + intDuplicateCount.ToString() + &quot;, Failed: &quot; + intFailedCount.ToString()]" />
        
        <!-- Save Log File -->
        <ui:WriteFile DisplayName="Save Execution Log" 
                      FileName="[dtConfig.Rows(0).Item(&quot;LogFolderPath&quot;).ToString() + &quot;\execution_log_&quot; + DateTime.Now.ToString(&quot;yyyyMMdd_HHmmss&quot;) + &quot;.txt&quot;]" 
                      Text="[string.Join(Environment.NewLine, lstExecutionLogs)]" 
                      Encoding="UTF-8" />
        
    </Sequence>
</Activity>